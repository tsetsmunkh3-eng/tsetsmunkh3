rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Scores collection
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isValidScore(request.resource.data);
      allow update, delete: if false;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['playerName', 'score', 'gameType', 'answers', 'createdAt'])
        && data.keys().size() == 5
        && data.playerName is string
        && data.playerName.size() >= 1
        && data.playerName.size() <= 50
        && data.score is int
        && data.score >= 0
        && data.gameType is string
        && (data.gameType == 'anime' || data.gameType == 'anime-emoji' || data.gameType == 'anime-character')
        && data.createdAt == request.time
        && data.answers is list
        && data.answers.size() <= 100;
    }
  }
}
